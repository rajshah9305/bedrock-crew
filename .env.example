# Universal NLP Interface Configuration

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Backend API base URL (Vercel deployment: usually empty or same as site URL)
VITE_API_URL=

# ─── Backend (FastAPI / Vercel Python) ──────────────────────────────────────
# Your Groq API key (required for backend processing)
GROQ_API_KEY=gsk_your_key_here

# ─── Optional ──────────────────────────────────────────────────────────────
# Rate limiting (per minute)
RATE_LIMIT_PER_MINUTE=20
